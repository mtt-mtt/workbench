<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="shopfloor_demo_app" model="shopfloor.app">
            <field name="name">Demo Shopfloor</field>
            <field name="code">shopfloor_demo</field>
            <field name="sequence">10</field>
            <field name="description">Minimal shopfloor seed data for workstation and gateway visibility.</field>
        </record>

        <record id="shopfloor_demo_profile" model="shopfloor.profile">
            <field name="name">Assembly Profile</field>
            <field name="code">shopfloor_demo_assembly</field>
            <field name="sequence">10</field>
            <field name="app_id" ref="shopfloor_demo_app"/>
            <field name="description">Default profile linked to the demo app.</field>
        </record>

        <record id="shopfloor_demo_menu_dashboard" model="shopfloor.menu">
            <field name="name">Dashboard</field>
            <field name="code">shopfloor_demo_menu_dashboard</field>
            <field name="sequence">10</field>
            <field name="app_id" ref="shopfloor_demo_app"/>
            <field name="profile_id" ref="shopfloor_demo_profile"/>
            <field name="action_type">screen</field>
            <field name="technical_action">dashboard</field>
            <field name="description">Demo dashboard entry point.</field>
        </record>

        <record id="shopfloor_demo_menu_execution" model="shopfloor.menu">
            <field name="name">Execution</field>
            <field name="code">shopfloor_demo_menu_execution</field>
            <field name="sequence">20</field>
            <field name="app_id" ref="shopfloor_demo_app"/>
            <field name="profile_id" ref="shopfloor_demo_profile"/>
            <field name="action_type">screen</field>
            <field name="technical_action">execution</field>
            <field name="description">Demo execution entry point.</field>
        </record>

        <record id="shopfloor_demo_scenario_start" model="shopfloor.scenario">
            <field name="name">Start Workorder</field>
            <field name="code">shopfloor_demo_scenario_start</field>
            <field name="sequence">10</field>
            <field name="app_id" ref="shopfloor_demo_app"/>
            <field name="profile_id" ref="shopfloor_demo_profile"/>
            <field name="menu_id" ref="shopfloor_demo_menu_execution"/>
            <field name="technical_name">start_workorder</field>
            <field name="description">Demo scenario for starting a work order.</field>
        </record>

        <record id="shopfloor_demo_workstation" model="shopfloor.workstation">
            <field name="name">Line A Workstation</field>
            <field name="code">shopfloor_demo_ws_line_a</field>
            <field name="sequence">10</field>
            <field name="app_id" ref="shopfloor_demo_app"/>
            <field name="profile_id" ref="shopfloor_demo_profile"/>
            <field name="terminal_uid">TERMINAL-LINE-A</field>
            <field name="default_printer_ref">PRN-LINE-A</field>
            <field name="gateway_ref">gateway_demo_main</field>
            <field name="location_ref">LINE-A</field>
            <field name="note">Demo workstation for the initial Shopfloor stack.</field>
        </record>

        <record id="shopfloor_demo_session" model="shopfloor.session">
            <field name="name">Demo Session</field>
            <field name="code">shopfloor_demo_session_1</field>
            <field name="sequence">10</field>
            <field name="state">active</field>
            <field name="app_id" ref="shopfloor_demo_app"/>
            <field name="profile_id" ref="shopfloor_demo_profile"/>
            <field name="workstation_id" ref="shopfloor_demo_workstation"/>
            <field name="note">Seed session for demo visibility.</field>
        </record>
    </data>
</odoo>
