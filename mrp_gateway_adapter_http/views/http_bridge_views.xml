<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gateway_http_bridge_tree" model="ir.ui.view">
        <field name="name">gateway.http.bridge.tree</field>
        <field name="model">gateway.http.bridge</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence"/>
                <field name="name"/>
                <field name="code"/>
                <field name="state"/>
                <field name="runtime_adapter_code"/>
                <field name="entry_id"/>
                <field name="workstation_id"/>
            </list>
        </field>
    </record>

    <record id="view_gateway_http_bridge_form" model="ir.ui.view">
        <field name="name">gateway.http.bridge.form</field>
        <field name="model">gateway.http.bridge</field>
        <field name="arch" type="xml">
            <form string="HTTP Bridge">
                <header>
                    <button name="action_sync_runtime_adapter" type="object" string="Sync Runtime" class="btn-primary"/>
                    <button name="action_regenerate_secret" type="object" string="Regenerate Secret" class="btn-secondary"/>
                    <button name="action_mark_ready" type="object" string="Ready" class="btn-secondary"/>
                    <button name="action_mark_disabled" type="object" string="Disable" class="btn-secondary"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,ready,degraded,offline,disabled"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="sequence"/>
                            <field name="active"/>
                            <field name="runtime_adapter_code"/>
                        </group>
                        <group>
                            <field name="runtime_adapter_id" readonly="1"/>
                            <field name="entry_id"/>
                            <field name="app_id"/>
                            <field name="workstation_id"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="bridge_key"/>
                            <field name="secret_token"/>
                            <field name="auth_mode"/>
                        </group>
                        <group>
                            <field name="endpoint_base_url"/>
                            <field name="last_request_at"/>
                            <field name="push_count"/>
                            <field name="heartbeat_count"/>
                            <field name="event_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Endpoints">
                            <field name="endpoint_ids">
                                <list editable="bottom">
                                    <field name="sequence"/>
                                    <field name="name"/>
                                    <field name="code"/>
                                    <field name="route_kind"/>
                                    <field name="path"/>
                                    <field name="http_method"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                        <page string="Config">
                            <field name="config_json" nolabel="1"/>
                            <field name="config_text" nolabel="1"/>
                        </page>
                        <page string="Diagnostics">
                            <field name="diagnostic_state" nolabel="1"/>
                            <field name="note" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_gateway_http_bridge_search" model="ir.ui.view">
        <field name="name">gateway.http.bridge.search</field>
        <field name="model">gateway.http.bridge</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="runtime_adapter_code"/>
                <field name="entry_id"/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
            </search>
        </field>
    </record>
</odoo>
