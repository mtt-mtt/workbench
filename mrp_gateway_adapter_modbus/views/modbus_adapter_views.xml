<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gateway_modbus_adapter_tree" model="ir.ui.view">
        <field name="name">gateway.modbus.adapter.tree</field>
        <field name="model">gateway.modbus.adapter</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence"/>
                <field name="name"/>
                <field name="code"/>
                <field name="transport"/>
                <field name="state"/>
                <field name="runtime_lifecycle_state"/>
                <field name="runtime_health_state"/>
                <field name="runtime_issue_count"/>
                <field name="runtime_open_issue_count"/>
                <field name="runtime_repair_issue_count"/>
                <field name="entry_id"/>
                <field name="runtime_adapter_id"/>
                <field name="last_snapshot_at"/>
                <field name="last_ack_at"/>
                <field name="runtime_capability_summary"/>
            </list>
        </field>
    </record>

    <record id="view_gateway_modbus_adapter_form" model="ir.ui.view">
        <field name="name">gateway.modbus.adapter.form</field>
        <field name="model">gateway.modbus.adapter</field>
        <field name="arch" type="xml">
            <form string="Gateway Modbus Adapter">
                <header>
                    <button name="action_sync_runtime_definition" type="object" string="Sync Runtime" class="btn-primary"/>
                    <button name="action_open_runtime_console" type="object" string="Console" class="btn-secondary"/>
                    <button name="action_open_protocol_probe" type="object" string="Probe" class="btn-secondary"/>
                    <button name="action_open_runtime_adapter" type="object" string="Open Runtime" class="btn-secondary"/>
                    <button name="action_open_runtime_issues" type="object" string="Runtime Issues" class="btn-secondary"/>
                    <button name="action_open_repairs" type="object" string="Repairs" class="btn-secondary"/>
                    <button name="action_open_runtime_diagnostics" type="object" string="Runtime Diagnostics" class="btn-secondary"/>
                    <button name="action_preview_read_plan" type="object" string="Preview Read Plan" class="btn-secondary"/>
                    <button name="action_preview_write_plan" type="object" string="Preview Write Plan" class="btn-secondary"/>
                    <button name="action_submit_test_snapshot" type="object" string="Test Snapshot" class="btn-secondary"/>
                    <button name="action_submit_test_write_ack" type="object" string="Test Write Ack" class="btn-secondary"/>
                    <button name="action_refresh_runtime" type="object" string="Refresh Runtime" class="btn-secondary"/>
                    <button name="action_repair_runtime" type="object" string="Repair Runtime" class="btn-secondary"/>
                    <button name="action_load_runtime" type="object" string="Load Runtime" class="btn-secondary"/>
                    <button name="action_reload_runtime" type="object" string="Reload Runtime" class="btn-secondary"/>
                    <button name="action_mark_ready" type="object" string="Mark Ready" class="btn-secondary"/>
                    <button name="action_mark_disabled" type="object" string="Disable" class="btn-secondary"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,ready,degraded,offline,disabled"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="sequence"/>
                            <field name="active"/>
                            <field name="state"/>
                        </group>
                        <group>
                            <field name="adapter_type" readonly="1"/>
                            <field name="entry_id"/>
                            <field name="runtime_adapter_id" readonly="1"/>
                            <field name="app_id"/>
                            <field name="workstation_id"/>
                        </group>
                    </group>
                    <group>
                        <group string="Transport">
                            <field name="transport"/>
                            <field name="host"/>
                            <field name="port"/>
                            <field name="serial_port"/>
                            <field name="baudrate"/>
                            <field name="parity"/>
                            <field name="stop_bits"/>
                            <field name="unit_id"/>
                        </group>
                        <group string="Timing">
                            <field name="poll_interval_seconds"/>
                            <field name="timeout_seconds"/>
                            <field name="retry_limit"/>
                            <field name="connection_target" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Runtime">
                            <group>
                                <group>
                                    <field name="runtime_adapter_id" readonly="1"/>
                                    <field name="runtime_lifecycle_state" readonly="1"/>
                                    <field name="runtime_health_state" readonly="1"/>
                                    <field name="runtime_issue_count" readonly="1"/>
                                    <field name="runtime_open_issue_count" readonly="1"/>
                                    <field name="runtime_repair_issue_count" readonly="1"/>
                                </group>
                                <group>
                                    <field name="runtime_capability_summary" readonly="1"/>
                                    <field name="runtime_diagnostic_summary" nolabel="1" readonly="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="Configuration">
                            <field name="config_json" nolabel="1"/>
                            <field name="config_text" nolabel="1"/>
                        </page>
                        <page string="Diagnostics">
                            <field name="diagnostic_state" nolabel="1"/>
                            <group>
                                <field name="last_snapshot_at"/>
                                <field name="last_ack_at"/>
                                <field name="snapshot_count"/>
                                <field name="ack_count"/>
                            </group>
                        </page>
                        <page string="Points">
                            <field name="point_ids">
                                <list editable="bottom">
                                    <field name="sequence"/>
                                    <field name="name"/>
                                    <field name="code"/>
                                    <field name="point_kind"/>
                                    <field name="register_address"/>
                                    <field name="register_count"/>
                                    <field name="data_type"/>
                                    <field name="writable"/>
                                </list>
                            </field>
                        </page>
                        <page string="Snapshots">
                            <field name="snapshot_ids">
                                <list>
                                    <field name="code"/>
                                    <field name="snapshot_kind"/>
                                    <field name="status"/>
                                    <field name="state"/>
                                    <field name="received_at"/>
                                    <field name="message"/>
                                </list>
                            </field>
                        </page>
                        <page string="Write Acks">
                            <field name="ack_ids">
                                <list>
                                    <field name="code"/>
                                    <field name="ack_kind"/>
                                    <field name="result_state"/>
                                    <field name="ack_at"/>
                                    <field name="response_text"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="note" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
