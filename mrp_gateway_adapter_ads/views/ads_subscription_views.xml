<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gateway_ads_subscription_tree" model="ir.ui.view">
        <field name="name">gateway.ads.subscription.tree</field>
        <field name="model">gateway.ads.subscription</field>
        <field name="arch" type="xml">
            <list string="ADS Subscriptions">
                <field name="code"/>
                <field name="adapter_id"/>
                <field name="symbol_id"/>
                <field name="subscription_mode"/>
                <field name="state"/>
                <field name="priority"/>
                <field name="notify_on_change"/>
                <field name="listener_count"/>
                <field name="last_subscribed_at"/>
                <field name="last_notified_at"/>
                <field name="dispatcher_signal"/>
            </list>
        </field>
    </record>

    <record id="view_gateway_ads_subscription_search" model="ir.ui.view">
        <field name="name">gateway.ads.subscription.search</field>
        <field name="model">gateway.ads.subscription</field>
        <field name="arch" type="xml">
            <search>
                <field name="code"/>
                <field name="adapter_id"/>
                <field name="symbol_id"/>
                <field name="subscription_key"/>
                <field name="subscription_mode"/>
                <field name="state"/>
                <filter string="Requested" name="requested" domain="[('state', '=', 'requested')]"/>
                <filter string="Subscribed" name="subscribed" domain="[('state', '=', 'subscribed')]"/>
                <filter string="Paused" name="paused" domain="[('state', '=', 'paused')]"/>
                <filter string="Error" name="error" domain="[('state', '=', 'error')]"/>
                <separator string="Group By"/>
                <filter string="Adapter" name="group_adapter" context="{'group_by': 'adapter_id'}"/>
                <filter string="Symbol" name="group_symbol" context="{'group_by': 'symbol_id'}"/>
                <filter string="Mode" name="group_mode" context="{'group_by': 'subscription_mode'}"/>
                <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

    <record id="view_gateway_ads_subscription_form" model="ir.ui.view">
        <field name="name">gateway.ads.subscription.form</field>
        <field name="model">gateway.ads.subscription</field>
        <field name="arch" type="xml">
            <form string="ADS Subscription">
                <header>
                    <button name="action_mark_requested" type="object" string="Request" class="btn-secondary"/>
                    <button name="action_mark_subscribed" type="object" string="Subscribe" class="btn-primary"/>
                    <button name="action_mark_paused" type="object" string="Pause" class="btn-secondary"/>
                    <button name="action_mark_error" type="object" string="Error" class="btn-secondary"/>
                    <button name="action_mark_cancelled" type="object" string="Cancel" class="btn-secondary"/>
                    <button name="action_open_symbol" type="object" string="Open Symbol" class="btn-secondary"/>
                    <button name="action_open_adapter" type="object" string="Open Adapter" class="btn-secondary"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,requested,subscribed,paused,error,cancelled"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="adapter_id"/>
                            <field name="symbol_id"/>
                            <field name="subscription_mode"/>
                            <field name="state"/>
                        </group>
                        <group>
                            <field name="subscription_key"/>
                            <field name="dispatcher_signal"/>
                            <field name="priority"/>
                            <field name="notify_on_change"/>
                            <field name="listener_count"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="last_subscribed_at"/>
                        <field name="last_unsubscribed_at"/>
                        <field name="last_notified_at"/>
                        <field name="last_error_at"/>
                    </group>
                    <field name="payload_json" nolabel="1"/>
                    <field name="last_error" nolabel="1"/>
                    <field name="note" nolabel="1"/>
                    <field name="notification_ids" readonly="1">
                        <list>
                            <field name="code"/>
                            <field name="event_kind"/>
                            <field name="state"/>
                            <field name="received_at"/>
                            <field name="dispatched_at"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
