<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gateway_ads_adapter_tree" model="ir.ui.view">
        <field name="name">gateway.ads.adapter.tree</field>
        <field name="model">gateway.ads.adapter</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence"/>
                <field name="code"/>
                <field name="name"/>
                <field name="state"/>
                <field name="runtime_lifecycle_state"/>
                <field name="runtime_health_state"/>
                <field name="runtime_issue_count"/>
                <field name="runtime_open_issue_count"/>
                <field name="runtime_repair_issue_count"/>
                <field name="ams_net_id"/>
                <field name="host"/>
                <field name="port"/>
                <field name="ads_port"/>
                <field name="symbol_count"/>
                <field name="subscribed_symbol_count"/>
                <field name="subscription_error_count"/>
                <field name="subscription_count"/>
                <field name="active_subscription_count"/>
                <field name="notification_count"/>
                <field name="runtime_capability_summary"/>
                <field name="last_sync_at"/>
            </list>
        </field>
    </record>

    <record id="view_gateway_ads_adapter_form" model="ir.ui.view">
        <field name="name">gateway.ads.adapter.form</field>
        <field name="model">gateway.ads.adapter</field>
        <field name="arch" type="xml">
            <form string="ADS Adapter">
                <header>
                    <button name="action_sync_runtime_definition" type="object" string="Sync Runtime" class="btn-primary"/>
                    <button name="action_open_runtime_console" type="object" string="Console" class="btn-secondary"/>
                    <button name="action_open_protocol_probe" type="object" string="Probe" class="btn-secondary"/>
                    <button name="action_open_runtime_adapter" type="object" string="Open Runtime" class="btn-secondary"/>
                    <button name="action_open_runtime_issues" type="object" string="Runtime Issues" class="btn-secondary"/>
                    <button name="action_open_repairs" type="object" string="Repairs" class="btn-secondary"/>
                    <button name="action_open_runtime_diagnostics" type="object" string="Runtime Diagnostics" class="btn-secondary"/>
                    <button name="action_preview_connectivity" type="object" string="Preview Connectivity" class="btn-secondary"/>
                    <button name="action_preview_symbol_map" type="object" string="Preview Symbol Map" class="btn-secondary"/>
                    <button name="action_preview_subscription_plan" type="object" string="Preview Subscriptions" class="btn-secondary"/>
                    <button name="action_open_subscriptions" type="object" string="Subscriptions" class="btn-secondary"/>
                    <button name="action_open_notifications" type="object" string="Notifications" class="btn-secondary"/>
                    <button name="action_subscribe_symbols" type="object" string="Subscribe Symbols" class="btn-secondary"/>
                    <button name="action_unsubscribe_symbols" type="object" string="Unsubscribe Symbols" class="btn-secondary"/>
                    <button name="action_push_test_notification" type="object" string="Test Callback" class="btn-secondary"/>
                    <button name="action_submit_test_read" type="object" string="Test Read" class="btn-secondary"/>
                    <button name="action_submit_test_write" type="object" string="Test Write" class="btn-secondary"/>
                    <button name="action_refresh_runtime" type="object" string="Refresh Runtime" class="btn-secondary"/>
                    <button name="action_repair_runtime" type="object" string="Repair Runtime" class="btn-secondary"/>
                    <button name="action_load_runtime" type="object" string="Load Runtime" class="btn-secondary"/>
                    <button name="action_reload_runtime" type="object" string="Reload Runtime" class="btn-secondary"/>
                    <button name="action_refresh_diagnostics" type="object" string="Refresh Diagnostics" class="btn-secondary"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,ready,degraded,offline,disabled"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="state"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="adapter_type" readonly="1"/>
                            <field name="entry_id"/>
                            <field name="app_id"/>
                            <field name="workstation_id"/>
                            <field name="runtime_adapter_id" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Connection">
                            <field name="host"/>
                            <field name="port"/>
                            <field name="ams_net_id"/>
                            <field name="ads_port"/>
                            <field name="connection_target" readonly="1"/>
                        </group>
                        <group string="Timing">
                            <field name="device_code"/>
                            <field name="poll_interval_seconds"/>
                            <field name="timeout_seconds"/>
                            <field name="retry_limit"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Runtime">
                            <group>
                                <group>
                                    <field name="runtime_lifecycle_state" readonly="1"/>
                                    <field name="runtime_health_state" readonly="1"/>
                                    <field name="runtime_issue_count" readonly="1"/>
                                    <field name="runtime_open_issue_count" readonly="1"/>
                                    <field name="runtime_repair_issue_count" readonly="1"/>
                                    <field name="symbol_count" readonly="1"/>
                                    <field name="subscribed_symbol_count" readonly="1"/>
                                    <field name="subscription_error_count" readonly="1"/>
                                    <field name="subscription_count" readonly="1"/>
                                    <field name="active_subscription_count" readonly="1"/>
                                    <field name="notification_count" readonly="1"/>
                                    <field name="open_notification_count" readonly="1"/>
                                    <field name="diagnostic_count" readonly="1"/>
                                </group>
                                <group>
                                    <field name="runtime_capability_summary" readonly="1"/>
                                    <field name="subscription_summary" readonly="1"/>
                                    <field name="notification_summary" readonly="1"/>
                                    <field name="runtime_diagnostic_summary" nolabel="1" readonly="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="Symbols">
                            <field name="symbol_ids">
                                <list editable="bottom">
                                    <field name="sequence"/>
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="symbol_path"/>
                                    <field name="index_group"/>
                                    <field name="index_offset"/>
                                    <field name="data_type"/>
                                    <field name="access_mode"/>
                                    <field name="writable"/>
                                    <field name="subscription_enabled"/>
                                    <field name="subscription_state"/>
                                    <field name="update_count"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                        <page string="Diagnostics">
                            <field name="diagnostic_ids" readonly="1">
                                <list>
                                    <field name="observed_at"/>
                                    <field name="kind"/>
                                    <field name="state"/>
                                    <field name="message"/>
                                    <field name="detail"/>
                                </list>
                            </field>
                        </page>
                        <page string="Configuration">
                            <field name="config_text" nolabel="1"/>
                            <field name="config_json" nolabel="1"/>
                            <field name="diagnostic_state" nolabel="1"/>
                            <field name="runtime_capability_json" nolabel="1"/>
                            <field name="note" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
