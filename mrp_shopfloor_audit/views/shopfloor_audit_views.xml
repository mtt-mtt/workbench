<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_shopfloor_audit_log_tree" model="ir.ui.view">
        <field name="name">shopfloor.audit.log.tree</field>
        <field name="model">shopfloor.audit.log</field>
        <field name="arch" type="xml">
            <list>
                <field name="event_at"/>
                <field name="event_type"/>
                <field name="severity"/>
                <field name="event_code"/>
                <field name="workstation_code"/>
                <field name="session_ref"/>
                <field name="execution_ref"/>
                <field name="gateway_command_ref"/>
                <field name="actor"/>
            </list>
        </field>
    </record>

    <record id="view_shopfloor_audit_log_form" model="ir.ui.view">
        <field name="name">shopfloor.audit.log.form</field>
        <field name="model">shopfloor.audit.log</field>
        <field name="arch" type="xml">
            <form string="Shopfloor Audit Log">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="event_at"/>
                            <field name="event_type"/>
                            <field name="severity"/>
                            <field name="event_code"/>
                        </group>
                        <group>
                            <field name="actor"/>
                            <field name="actor_user_id"/>
                            <field name="workstation_code"/>
                            <field name="session_ref"/>
                            <field name="execution_ref"/>
                            <field name="execution_id"/>
                            <field name="gateway_command_ref"/>
                        </group>
                    </group>
                    <group>
                        <field name="payload"/>
                        <field name="result"/>
                    </group>
                    <group>
                        <field name="message"/>
                        <field name="note"/>
                        <field name="processed_at"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_shopfloor_audit_log_search" model="ir.ui.view">
        <field name="name">shopfloor.audit.log.search</field>
        <field name="model">shopfloor.audit.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="event_code"/>
                <field name="event_type"/>
                <field name="workstation_code"/>
                <field name="session_ref"/>
                <field name="actor"/>
                <filter string="Business" name="business" domain="[('event_type', '=', 'business')]"/>
                <filter string="Device" name="device" domain="[('event_type', '=', 'device')]"/>
                <filter string="Exception" name="exception" domain="[('event_type', '=', 'exception')]"/>
            </search>
        </field>
    </record>

    <record id="action_shopfloor_audit_log" model="ir.actions.act_window">
        <field name="name">Audit Logs</field>
        <field name="res_model">shopfloor.audit.log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_shopfloor_audit_log_search"/>
    </record>

    <menuitem
        id="menu_shopfloor_audit_root"
        name="Audit"
        parent="mrp_shopfloor_core.menu_shopfloor_operations"
        sequence="30"
        groups="mrp.group_mrp_user"
    />

    <menuitem
        id="menu_shopfloor_audit_logs"
        name="Logs"
        parent="menu_shopfloor_audit_root"
        action="action_shopfloor_audit_log"
        sequence="10"
        groups="mrp.group_mrp_user"
    />
</odoo>
