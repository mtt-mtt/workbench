<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gateway_s7_tag_list" model="ir.ui.view">
        <field name="name">gateway.s7.tag.list</field>
        <field name="model">gateway.s7.tag</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence"/>
                <field name="code"/>
                <field name="name"/>
                <field name="adapter_id"/>
                <field name="db_number"/>
                <field name="address"/>
                <field name="bit_offset"/>
                <field name="byte_length"/>
                <field name="data_type"/>
                <field name="access_mode"/>
                <field name="state"/>
            </list>
        </field>
    </record>
    <record id="view_gateway_s7_tag_form" model="ir.ui.view">
        <field name="name">gateway.s7.tag.form</field>
        <field name="model">gateway.s7.tag</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="adapter_id"/>
                            <field name="state"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="db_number"/>
                            <field name="address"/>
                            <field name="bit_offset"/>
                            <field name="byte_length"/>
                            <field name="data_type"/>
                            <field name="access_mode"/>
                        </group>
                    </group>
                    <group>
                        <field name="last_value"/>
                        <field name="last_status"/>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
