<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gateway_s7_write_ack_list" model="ir.ui.view">
        <field name="name">gateway.s7.write.ack.list</field>
        <field name="model">gateway.s7.write.ack</field>
        <field name="arch" type="xml">
            <list>
                <field name="sent_at"/>
                <field name="acked_at"/>
                <field name="adapter_id"/>
                <field name="tag_id"/>
                <field name="state"/>
                <field name="command_code"/>
                <field name="ack_code"/>
            </list>
        </field>
    </record>
    <record id="view_gateway_s7_write_ack_form" model="ir.ui.view">
        <field name="name">gateway.s7.write.ack.form</field>
        <field name="model">gateway.s7.write.ack</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="adapter_id"/>
                        <field name="tag_id"/>
                        <field name="state"/>
                        <field name="command_code"/>
                        <field name="ack_code"/>
                    </group>
                    <group>
                        <field name="requested_value"/>
                        <field name="acked_value"/>
                        <field name="sent_at"/>
                        <field name="acked_at"/>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
