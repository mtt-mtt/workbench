<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gateway_s7_snapshot_list" model="ir.ui.view">
        <field name="name">gateway.s7.snapshot.list</field>
        <field name="model">gateway.s7.snapshot</field>
        <field name="arch" type="xml">
            <list>
                <field name="collected_at"/>
                <field name="adapter_id"/>
                <field name="code"/>
                <field name="state"/>
                <field name="name"/>
            </list>
        </field>
    </record>
    <record id="view_gateway_s7_snapshot_form" model="ir.ui.view">
        <field name="name">gateway.s7.snapshot.form</field>
        <field name="model">gateway.s7.snapshot</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="adapter_id"/>
                        <field name="code"/>
                        <field name="state"/>
                        <field name="collected_at"/>
                    </group>
                    <group>
                        <field name="payload_json"/>
                        <field name="result_json"/>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
