<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gateway_s7_adapter_list" model="ir.ui.view">
        <field name="name">gateway.s7.adapter.list</field>
        <field name="model">gateway.s7.adapter</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence"/>
                <field name="code"/>
                <field name="name"/>
                <field name="state"/>
                <field name="runtime_lifecycle_state"/>
                <field name="runtime_health_state"/>
                <field name="runtime_issue_count"/>
                <field name="runtime_open_issue_count"/>
                <field name="host"/>
                <field name="port"/>
                <field name="rack"/>
                <field name="slot"/>
                <field name="point_count"/>
                <field name="snapshot_count"/>
                <field name="ack_count"/>
                <field name="runtime_capability_summary"/>
            </list>
        </field>
    </record>
    <record id="view_gateway_s7_adapter_form" model="ir.ui.view">
        <field name="name">gateway.s7.adapter.form</field>
        <field name="model">gateway.s7.adapter</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_sync_runtime_definition" type="object" string="Sync Runtime" class="btn-primary"/>
                    <button name="action_open_runtime_adapter" type="object" string="Open Runtime" class="btn-secondary"/>
                    <button name="action_open_runtime_issues" type="object" string="Runtime Issues" class="btn-secondary"/>
                    <button name="action_open_runtime_diagnostics" type="object" string="Runtime Diagnostics" class="btn-secondary"/>
                    <button name="action_refresh_runtime" type="object" string="Refresh Runtime" class="btn-secondary"/>
                    <button name="action_repair_runtime" type="object" string="Repair Runtime" class="btn-secondary"/>
                    <button name="action_reload_runtime" type="object" string="Reload Runtime" class="btn-secondary"/>
                    <button name="action_refresh_diagnostics" type="object" string="Refresh Diagnostics" class="btn-secondary"/>
                    <button name="action_preview_read_plan" type="object" string="Preview Read Plan" class="btn-secondary"/>
                    <button name="action_preview_write_plan" type="object" string="Preview Write Plan" class="btn-secondary"/>
                    <button name="action_submit_test_snapshot" type="object" string="Test Snapshot" class="btn-secondary"/>
                    <button name="action_submit_test_write_ack" type="object" string="Test Write Ack" class="btn-secondary"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,ready,degraded,offline,disabled"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="state"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="host"/>
                            <field name="port"/>
                            <field name="rack"/>
                            <field name="slot"/>
                            <field name="cpu"/>
                        </group>
                    </group>
                    <group string="Runtime">
                        <field name="entry_id"/>
                        <field name="app_id"/>
                        <field name="workstation_id"/>
                        <field name="runtime_adapter_id" readonly="1"/>
                        <field name="runtime_lifecycle_state" readonly="1"/>
                        <field name="runtime_health_state" readonly="1"/>
                        <field name="runtime_issue_count" readonly="1"/>
                        <field name="runtime_open_issue_count" readonly="1"/>
                        <field name="connection_target" readonly="1"/>
                        <field name="point_count" readonly="1"/>
                        <field name="snapshot_count" readonly="1"/>
                        <field name="ack_count" readonly="1"/>
                        <field name="runtime_capability_summary" readonly="1"/>
                        <field name="last_snapshot_at" readonly="1"/>
                        <field name="last_ack_at" readonly="1"/>
                        <field name="runtime_last_refresh_at" readonly="1"/>
                        <field name="runtime_last_repair_at" readonly="1"/>
                        <field name="runtime_last_reload_at" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Tags">
                            <field name="tag_ids">
                                <list editable="bottom">
                                    <field name="sequence"/>
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="db_number"/>
                                    <field name="address"/>
                                    <field name="bit_offset"/>
                                    <field name="byte_length"/>
                                    <field name="data_type"/>
                                    <field name="access_mode"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                        <page string="Snapshots">
                            <field name="snapshot_ids" readonly="1">
                                <list>
                                    <field name="collected_at"/>
                                    <field name="code"/>
                                    <field name="state"/>
                                    <field name="name"/>
                                </list>
                            </field>
                        </page>
                        <page string="Write Acks">
                            <field name="ack_ids" readonly="1">
                                <list>
                                    <field name="sent_at"/>
                                    <field name="acked_at"/>
                                    <field name="state"/>
                                    <field name="tag_id"/>
                                    <field name="command_code"/>
                                    <field name="ack_code"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="config_text"/>
                            <field name="config_json"/>
                            <field name="diagnostic_state"/>
                            <field name="runtime_diagnostic_summary"/>
                            <field name="runtime_capability_json"/>
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
