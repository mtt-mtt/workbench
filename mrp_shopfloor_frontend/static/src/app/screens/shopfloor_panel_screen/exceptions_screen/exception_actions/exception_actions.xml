<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="mrp_shopfloor_frontend.ShopfloorExceptionActions" owl="1">
        <section class="o_mrp_shopfloor_detail_panel o_mrp_shopfloor_exception_actions_panel">
            <div class="o_mrp_shopfloor_card_label">Exception transitions</div>
            <div class="o_mrp_shopfloor_panel_stack">
                <ShopfloorStatusSummary items="summaryItems" title="'Exception summary'" subtitle="'Use the actions below to move the exception through the workflow.'"/>
                <t t-if="runtimeFeedback">
                    <ShopfloorFeedbackBar
                        label="runtimeFeedback.label"
                        detail="runtimeFeedback.detail"
                        tone="runtimeFeedback.tone"
                        compact="true"
                    />
                </t>
                <div class="o_mrp_shopfloor_api_detail">
                    <t t-esc="branchSummaryText"/>
                </div>
                <div class="o_mrp_shopfloor_exception_action_grid">
                    <t t-foreach="actions" t-as="action" t-key="action.key">
                        <button type="button"
                                class="btn o_mrp_shopfloor_touch_button"
                                t-att-class="action.buttonClass"
                                t-att-data-action="action.key"
                                t-att-data-label="action.label"
                                t-att-data-confirm-label="action.confirmLabel"
                                t-att-data-message="action.message"
                                t-att-data-severity="action.severity"
                                t-att-data-state="action.state"
                                t-att-data-description="action.description"
                                t-on-click="requestAction">
                            <span><t t-esc="action.label"/></span>
                            <small><t t-esc="action.description"/></small>
                        </button>
                    </t>
                </div>
            </div>
        </section>
        <t t-if="hasPendingAction">
            <div class="o_mrp_shopfloor_modal_backdrop" t-on-click="cancelAction">
                <div class="o_mrp_shopfloor_modal_card o_mrp_shopfloor_exception_modal" t-att-class="pendingActionToneClass" t-on-click.stop="stopModalClick">
                    <div class="o_mrp_shopfloor_modal_header">
                        <div>
                            <div class="o_mrp_shopfloor_card_label">Confirm transition</div>
                            <div class="o_mrp_shopfloor_detail_title"><t t-esc="pendingActionTitle"/></div>
                        </div>
                        <span class="badge rounded-pill" t-att-class="pendingActionBadgeClass">
                            <t t-esc="pendingAction.key"/>
                        </span>
                    </div>
                    <p class="o_mrp_shopfloor_api_detail o_mrp_shopfloor_modal_lead">
                        <t t-esc="pendingActionSummary"/>
                    </p>
                    <div class="o_mrp_shopfloor_modal_body">
                        <div class="o_mrp_shopfloor_modal_detail">
                            <span class="badge rounded-pill text-bg-secondary">Severity <t t-esc="pendingAction.severity"/></span>
                            <span class="badge rounded-pill text-bg-secondary">Next state <t t-esc="pendingAction.state"/></span>
                        </div>
                        <p class="o_mrp_shopfloor_modal_hint">
                            <t t-esc="pendingAction.description"/>
                        </p>
                        <div class="o_mrp_shopfloor_exception_actions o_mrp_shopfloor_modal_actions">
                            <button type="button"
                                    class="btn btn-lg btn-primary"
                                    t-att-data-action="pendingAction.key"
                                    t-att-data-label="pendingAction.label"
                                    t-att-data-confirm-label="pendingAction.confirmLabel"
                                    t-att-data-message="pendingAction.message"
                                    t-att-data-severity="pendingAction.severity"
                                    t-att-data-state="pendingAction.state"
                                    t-att-data-description="pendingAction.description"
                                    t-on-click="confirmAction">
                                <span>Confirm</span>
                                <small>Apply this change now</small>
                            </button>
                            <button type="button" class="btn btn-lg btn-outline-light" t-on-click="cancelAction">
                                <span>Cancel</span>
                                <small>Leave the exception unchanged</small>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </t>
</templates>
