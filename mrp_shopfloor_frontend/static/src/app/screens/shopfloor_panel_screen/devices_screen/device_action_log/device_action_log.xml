<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="mrp_shopfloor_frontend.ShopfloorDeviceActionLog" owl="1">
        <section class="o_mrp_shopfloor_detail_panel o_mrp_shopfloor_detail_panel--compact">
            <div class="o_mrp_shopfloor_api_head">
                <div>
                    <div class="o_mrp_shopfloor_card_label">Recent actions</div>
                    <div class="o_mrp_shopfloor_detail_title">Local queue feedback</div>
                </div>
                <span class="badge rounded-pill text-bg-secondary">
                    <t t-esc="entries.length"/>
                </span>
            </div>
            <ShopfloorFeedbackBar
                label="commandFeedback.label"
                detail="commandFeedback.detail"
                tone="commandFeedback.tone"
                onAction="noopFeedbackAction"
                compact="true"
            />
            <t t-if="runtimeFeedback">
                <ShopfloorFeedbackBar
                    label="runtimeFeedback.label"
                    detail="runtimeFeedback.detail"
                    tone="runtimeFeedback.tone"
                    onAction="noopFeedbackAction"
                    compact="true"
                />
            </t>
            <ShopfloorStatusSummary items="commandSummaryItems" compact="true"/>
            <div class="o_mrp_shopfloor_command_lifecycle mt-3">
                <t t-foreach="commandStateSteps" t-as="step" t-key="step.key">
                    <span class="badge rounded-pill me-1 mb-1"
                          t-att-class="'text-bg-' + (step.active ? commandFeedback.tone : 'secondary')">
                        <t t-esc="step.label"/>
                    </span>
                </t>
            </div>
            <div class="o_mrp_shopfloor_detail_meta mt-2">
                <span>Latest state <t t-esc="commandStateLabel"/></span>
                <span><t t-esc="commandStateDetail"/></span>
            </div>
            <t t-if="latestPrintExecutionLabel">
                <div class="o_mrp_shopfloor_detail_meta mt-2">
                    <span class="badge rounded-pill" t-att-class="'text-bg-' + (commandSummary.latestPrintExecutionTone || 'info')">
                        <t t-esc="latestPrintExecutionLabel"/>
                    </span>
                </div>
            </t>
            <t t-if="latestPrintExecutionDetails.length">
                <div class="o_mrp_shopfloor_detail_meta mt-2">
                    <t t-foreach="latestPrintExecutionDetails" t-as="detail" t-key="detail.key">
                        <span class="badge rounded-pill text-bg-light">
                            <t t-esc="detail.label"/>
                        </span>
                    </t>
                </div>
            </t>
            <t t-if="entries.length">
                <div class="o_mrp_shopfloor_timeline o_mrp_shopfloor_timeline--compact mt-3">
                    <t t-foreach="displayEntries" t-as="displayEntry" t-key="displayEntry.id">
                        <div class="o_mrp_shopfloor_timeline_item">
                            <div class="o_mrp_shopfloor_timeline_item_head">
                                <strong><t t-esc="displayEntry.label"/></strong>
                                <span class="badge rounded-pill" t-att-class="'text-bg-' + (displayEntry.tone || 'secondary')">
                                    <t t-esc="displayEntry.statusLabel || displayEntry.status"/>
                                </span>
                            </div>
                            <small>
                                <t t-esc="displayEntry.deviceName"/> | <t t-esc="displayEntry.deviceCode"/> | <t t-esc="displayEntry.command"/>
                            </small>
                            <small>
                                <t t-esc="displayEntry.detail"/>
                            </small>
                            <t t-if="displayEntry.printExecutionLabel">
                            <small>
                                <span class="badge rounded-pill" t-att-class="'text-bg-' + (displayEntry.printExecutionTone || 'info')">
                                    <t t-esc="displayEntry.printExecutionLabel"/>
                                </span>
                            </small>
                            </t>
                            <t t-if="displayEntry.printExecutionDetails && displayEntry.printExecutionDetails.length">
                                <small>
                                    <t t-foreach="displayEntry.printExecutionDetails" t-as="detail" t-key="detail.key">
                                        <span class="badge rounded-pill text-bg-light me-1">
                                            <t t-esc="detail.label"/>
                                        </span>
                                    </t>
                                </small>
                            </t>
                            <small>
                                <t t-esc="displayEntry.createdAt"/>
                            </small>
                        </div>
                    </t>
                </div>
            </t>
            <t t-else="">
                <div class="o_mrp_shopfloor_empty">
                    Confirm a device action to populate the gateway.command trail and surface queued, sent, acknowledged, done, and failed states here.
                </div>
            </t>
        </section>
    </t>
</templates>
