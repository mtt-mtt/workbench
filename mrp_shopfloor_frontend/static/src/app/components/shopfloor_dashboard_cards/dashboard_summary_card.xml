<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="mrp_shopfloor_frontend.ShopfloorDashboardSummaryCard" owl="1">
        <article class="o_mrp_shopfloor_detail_panel">
            <div class="o_mrp_shopfloor_card_label"><t t-esc="props.label"/></div>
            <div class="o_mrp_shopfloor_detail_title"><t t-esc="props.title"/></div>
            <div class="o_mrp_shopfloor_detail_meta">
                <t t-if="props.badges.length">
                    <t t-foreach="props.badges" t-as="badge" t-foreach-index="badgeIndex" t-key="badgeIndex">
                        <span><t t-esc="badge"/></span>
                    </t>
                </t>
            </div>
        </article>
    </t>
</templates>
